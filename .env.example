TESTCODE_COZE_ACCESS_TOKEN=your-coze-token
TESTCODE_COZE_BASE_URL=https://api.coze.com
TESTCODE_COZE_TIMEOUT_SECONDS=30

TESTCODE_DIFY_API_KEY=your-dify-api-key
TESTCODE_DIFY_BASE_URL=https://api.dify.ai
TESTCODE_DIFY_TIMEOUT_SECONDS=30
TESTCODE_DIFY_CACHE_ENABLED=true
TESTCODE_DIFY_CACHE_DIRECTORY=.cache/dify
TESTCODE_DIFY_CACHE_TTL_SECONDS=86400
TESTCODE_DIFY_CACHE_BACKEND=file
TESTCODE_DIFY_CACHE_REDIS_URL=redis://redis:6379/0
TESTCODE_DIFY_CACHE_REDIS_PREFIX=testcode:dify

TESTCODE_N8N_BASE_URL=http://n8n:5678/api
TESTCODE_N8N_TIMEOUT_SECONDS=30
